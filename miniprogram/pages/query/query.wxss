.essay-hero{padding-bottom:26rpx}
.essay-preview{width:100%;height:360rpx;margin-top:20rpx;border-radius:24rpx;background:#ede7da}
.upload-actions{display:flex;align-items:stretch;gap:16rpx;flex-wrap:wrap;margin-top:18rpx}
.upload-btn{flex:1 1 260rpx;min-width:0}
.btn.disabled,.btn[disabled]{opacity:.55;background:#9aa89f!important;color:#fffdf7!important}
.upload-tip{margin-top:16rpx;color:#8b8173;font-size:24rpx;line-height:1.55}
.result-head{display:flex;align-items:center;justify-content:space-between;gap:16rpx}
.mini-btn{margin:0;padding:0 20rpx;min-height:58rpx;line-height:58rpx;border-radius:18rpx;background:#ede7da;color:#1f4d3a;font-size:24rpx}
.guide-card{background:#fffaf0}
.tip-line{font-size:25rpx;color:#58645d;line-height:1.75;margin:8rpx 0}