<view class="container">
  <view class="hero mine-hero">
    <view class="hero-title">我的</view>
    <view class="hero-subtitle">查看记录和设置。</view>
  </view>

  <view class="section card">
    <view class="result-head">
      <view class="section-title">最近批改</view>
      <button class="mini-btn" wx:if="{{records.length}}" bindtap="clearRecords">清空</button>
    </view>
    <view class="divider"></view>

    <view wx:if="{{!records.length}}" class="empty small-empty">暂无批改记录</view>

    <view wx:for="{{records}}" wx:key="id" class="record-item">
      <view class="record-head">
        <view class="record-title">{{item.topic}}</view>
        <button class="mini-btn ghost-mini" data-id="{{item.id}}" bindtap="copyRecord">复制</button>
      </view>
      <view class="record-time">{{item.time}}</view>
      <view class="record-summary">{{item.summary}}</view>
    </view>
  </view>

  <view class="section card">
    <view class="section-title">说明</view>
    <view class="divider"></view>
    <view class="tip-line" wx:for="{{tips}}" wx:key="*this">{{index + 1}}. {{item}}</view>
  </view>
</view>
