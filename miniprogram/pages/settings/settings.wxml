<view class="container">
  <view class="card">
    <view class="card-title">服务地址</view>
    <view class="card-meta">正式环境使用 HTTPS 地址。</view>
    <view class="divider"></view>
    <input class="input" value="{{baseUrl}}" bindinput="onInput" placeholder="https://shizheng-kb.onrender.com"/>
    <view style="height:18rpx"></view>
    <view class="settings-actions">
      <button class="btn settings-btn" bindtap="save">保存配置</button>
      <button class="btn secondary settings-btn" disabled="{{checking}}" bindtap="checkService">{{checking?'检测中':'测试连接'}}</button>
    </view>
    <view wx:if="{{statusText}}" class="status-line">{{statusText}}</view>
  </view>
</view>
